---
import ArchitectureExplorer from './ArchitectureExplorer.astro';
import { copyForLocale } from '../i18n/site-copy';

const base = import.meta.env.BASE_URL.endsWith('/')
	? import.meta.env.BASE_URL
	: `${import.meta.env.BASE_URL}/`;
const localeBase = `${base}${Astro.currentLocale === 'es' ? 'es/' : ''}`;
const landing = copyForLocale(Astro.currentLocale).landing;
---

<div class="landing-page">
	<section class="landing-intro" aria-labelledby="landing-intro-title">
		<div class="landing-section-heading">
			<p class="landing-eyebrow">{landing.eyebrow}</p>
			<h2 id="landing-intro-title" set:html={landing.title} />
		</div>
		<p class="landing-intro__copy">{landing.intro}</p>
		<dl class="landing-principles">
			{landing.principles.map((principle) => (
				<div>
					<dt>{principle.term}</dt>
					<dd>{principle.description}</dd>
				</div>
			))}
		</dl>
	</section>

	<ArchitectureExplorer />

	<section class="landing-responsibilities" aria-labelledby="responsibilities-title">
		<div class="landing-section-heading landing-section-heading--split">
			<div>
				<p class="landing-eyebrow">{landing.responsibilitiesEyebrow}</p>
				<h2 id="responsibilities-title" set:html={landing.responsibilitiesTitle} />
			</div>
			<p>{landing.responsibilitiesIntro}</p>
		</div>
		<div class="responsibility-grid">
			{landing.responsibilities.map((item) => (
				<a class="responsibility-card" href={`${localeBase}${item.href}`}>
					<div class="responsibility-card__meta">
						<span>{item.index}</span>
						<span>{item.label}</span>
					</div>
					<h3>{item.title}</h3>
					<p>{item.description}</p>
					<span class="responsibility-card__link" aria-hidden="true">{landing.learnMore} <span>→</span></span>
				</a>
			))}
		</div>
	</section>

	<section class="landing-paths" aria-labelledby="paths-title">
		<div class="landing-paths__heading">
			<p class="landing-eyebrow">{landing.pathsEyebrow}</p>
			<h2 id="paths-title">{landing.pathsTitle}</h2>
		</div>
		<nav class="landing-paths__grid" aria-label={landing.pathsLabel}>
			{landing.paths.map((path) => (
				<a href={`${localeBase}${path.href}`}>
					<span class="landing-paths__eyebrow">{path.eyebrow}</span>
					<strong>{path.title}</strong>
					<small>{path.description}</small>
					<span class="landing-paths__arrow" aria-hidden="true">→</span>
				</a>
			))}
		</nav>
	</section>
</div>
